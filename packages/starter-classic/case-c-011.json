  "lessons": [
    "交易正确不只看方向，还要看是否按可接受价格成交。",
    "限价单未成交不是失败，旧计划失效后不取消才是问题。",
    "卖出后马上买回要检查 T+1 和 good faith 类风险。"
  ],
  "learning": {
    "title": "订单执行和结算纪律",
    "concept": "窄幅行情里，收益可能很小，滑点、价差和结算纪律会变得更重要。训练重点是提交、等待、取消和复查订单。",
    "rules": [
      "薄成交标的优先用限价单，并设置有效期。",
      "挂单理由失效后要主动取消，不让旧计划继续运行。",
      "卖出后再买入前，先确认资金结算状态。"
    ],
    "terms": [
      {
        "name": "滑点",
        "description": "预期成交价和实际成交价之间的差异。"
