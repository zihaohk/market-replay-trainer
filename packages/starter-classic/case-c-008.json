  "lessons": [
    "热门资产最容易让人把故事当证据。",
    "涨得快不等于风险低，可能意味着预期更拥挤。",
    "泡沫训练重点不是抓顶，而是避免用情绪加仓。"
  ],
  "learning": {
    "title": "追高与泡沫纪律",
    "concept": "热门股快速上涨会制造赚钱幻觉。训练重点是区分证据和热度，提前写好止损和退出计划。",
    "rules": [
      "不能把社交热度当作唯一买入理由。",
      "如果买入热门股，仓位必须小，止损必须明确。",
      "上涨后想加仓，必须重新评估风险收益，而不是奖励自己。"
    ],
    "terms": [
      {
        "name": "FOMO",
        "description": "害怕错过而追涨。"
