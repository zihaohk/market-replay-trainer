  "learning": {
    "title": "财报与预期差",
    "concept": "市场交易的是“结果相对预期”。即使收入增长，如果估值和指引不匹配，股价也可能承压。",
    "rules": [
      "财报前不要用满仓赌方向。",
      "财报后先分解收入、利润、指引和估值，再做动作。",
      "如果股价已提前上涨，要把预期已反映写进理由。"
    ],
    "terms": [
      {
        "name": "预期差",
        "description": "实际信息和市场原本预期之间的差异。"
      },
      {
        "name": "指引",
        "description": "公司对未来收入、利润或业务趋势的展望。"
      },
      {
        "name": "估值压力",
        "description": "价格已经包含较高期待，信息稍弱就可能下跌。"
      }
    ],
    "quiz": {
      "question": "财报看起来不错但股价下跌，最合理的第一反应是什么？",
      "options": [
